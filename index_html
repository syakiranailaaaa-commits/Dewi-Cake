<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SmartCake</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial;
}

body{
    background:#fff5f7;
}

header{
    background:#ff7aa2;
    color:white;
    text-align:center;
    padding:50px 20px;
}

header h1{
    font-size:55px;
}

header p{
    margin-top:10px;
    font-size:18px;
}

.container{
    width:90%;
    max-width:1000px;
    margin:auto;
    padding:40px 0;
}

.card{
    background:white;
    padding:30px;
    border-radius:15px;
    box-shadow:0 0 15px rgba(0,0,0,0.1);
}

h2{
    margin-bottom:20px;
    color:#ff4f87;
}

.gallery{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
    margin-bottom:40px;
}

.gallery img{
    width:100%;
    border-radius:15px;
    height:250px;
    object-fit:cover;
}

form{
    display:grid;
    gap:15px;
}

input, textarea, select{
    padding:12px;
    border:1px solid #ccc;
    border-radius:10px;
}

button{
    background:#ff4f87;
    color:white;
    border:none;
    padding:15px;
    border-radius:10px;
    cursor:pointer;
    font-size:16px;
}

button:hover{
    background:#ff2f72;
}

footer{
    text-align:center;
    padding:20px;
    color:#666;
}

</style>
</head>

<body>

<header>
    <h1>🎂 SmartCake</h1>
    <p>Custom Cake untuk Hari Spesialmu</p>
</header>

<div class="container">

<div class="card">

<h2>Galeri Cake</h2>

<div class="gallery">
<img src="https://images.unsplash.com/photo-1578985545062-69928b1d9587">
<img src="https://images.unsplash.com/photo-1535141192574-5d4897c12636">
<img src="https://images.unsplash.com/photo-1464349095431-e9a21285b5f3">
</div>

<h2>Form Pemesanan</h2>

<form>

<input type="text" placeholder="Nama Lengkap">

<input type="text" placeholder="Nomor WhatsApp">

<textarea placeholder="Alamat Lengkap"></textarea>

<select>
<option>Pilih Ukuran Cake</option>
<option>15 cm</option>
<option>20 cm</option>
<option>25 cm</option>
</select>

<select>
<option>Pilih Rasa</option>
<option>Chocolate</option>
<option>Vanilla</option>
<option>Red Velvet</option>
<option>Matcha</option>
</select>

<input type="text" placeholder="Tulisan di Kue">

<label>Tanggal Pengambilan</label>
<input type="date">

<label>Jam Pengambilan</label>
<input type="time">

<button type="submit">
Pesan Sekarang
</button>

</form>

</div>

</div>

<footer>
© 2026 SmartCake
</footer>

</body>
</html>
